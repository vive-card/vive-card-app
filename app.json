{
  "expo": {
    "name": "VIVE CARD",
    "slug": "vive-card-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0f12"
    },
    "assetBundlePatterns": [
      "*/"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vivecard.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0f12"
      },
      "package": "com.vivecard.app"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "scheme": "vivecard"
  }
}
